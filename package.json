{
  "name": "taskcore",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "task": "dist/core/cli/task.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test core/test/*.test.ts",
    "test:middle": "tsx --test middle/test/*.test.ts",
    "test:all": "tsx --test core/test/*.test.ts middle/test/*.test.ts",
    "daemon": "node --import tsx middle/daemon.ts",
    "roomd": "node --import tsx middle/roomd.ts",
    "migrate": "node --import tsx middle/migrate.ts",
    "task": "node --import tsx core/cli/task.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
